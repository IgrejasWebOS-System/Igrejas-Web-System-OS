# ============================================================
# IgrejasWeb System OS -- Variaveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no GitHub.
# ============================================================

# Supabase -- encontre em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase Service Role (apenas server-side, nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL do sistema (local ou producao)
NEXT_PUBLIC_APP_URL=http://localhost:3000
